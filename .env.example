# SP Server Configuration
PORT=3001
SESSION_SECRET=foo-bar

# SAML Service Provider (SP) Configuration
SAML_SP_ISSUER=http://localhost:3001/saml/metadata
SAML_SP_CALLBACK_URL=http://localhost:3001/saml/callback

# SAML Identity Provider (IDP) Configuration - Curity Server
# Option 1: Auto-configure from IDP metadata URL (RECOMMENDED)
SAML_IDP_METADATA_URL=https://localhost:8443/saml/sso/metadata

# Option 2: Manual configuration (if not using SAML_IDP_METADATA_URL)
# SAML_IDP_ENTRY_POINT=https://localhost:8443/saml/sso
# SAML_IDP_CERT=MIID... (IDP certificate here) ...

# IDP Logout URL - Curity Identity Server logout endpoint with redirect back to SP
# SAML_IDP_LOGOUT_REDIRECT_URL=https://localhost:8443/dev/authn/authenticate/logout?redirect_uri=http://localhost:3001/saml/logout/callback

# Set to true ONLY for development/testing to skip validation
SAML_IDP_SKIP_CERT_VALIDATION=false

# -----------------------------------------------------------------------------
# Unsolicited SAML Response test
# -----------------------------------------------------------------------------
# The diagnostic app can hand-craft, sign and POST an unsolicited SAML 2.0
# Response to a Curity SAML2 authenticator's ACS endpoint, then drive the OAuth
# code exchange end-to-end. All values below have sensible defaults baked in;
# override here when the host Curity setup deviates.

# Where the unsolicited Response is POSTed (the saml2-sp authenticator's ACS)
# UNSOLICITED_ACS_URL=https://localhost:8443/dev/authn/authenticate/saml2-sp

# <saml:Audience> default — should match the SP's <issuer-entity-id>.
# Change in the UI to demo the audience-validation gap.
# UNSOLICITED_AUDIENCE=https://localhost:8443/dev/authn/anonymous/saml2-sp/metadata

# <saml:Issuer> for both Response and Assertion — must match what the host SP
# has registered as the trusted IdP entity id.
# UNSOLICITED_IDP_ENTITY_ID=https://saml-idp.curity.local:9443/saml/sso/metadata

# Bootstrap params Curity needs in the POST form body to dispatch to the
# saml2-sp handler.
# UNSOLICITED_OAUTH_PROFILE_ID=oauth-dev
# UNSOLICITED_RESUME_PATH=/dev/oauth/authorize

# OAuth client used to exchange the code for tokens after the SAML POST.
# Defaults to a local-dev client where secret == id.
# UNSOLICITED_CLIENT_ID=saml2_unsolicited_client
# UNSOLICITED_CLIENT_SECRET=saml2_unsolicited_client
# UNSOLICITED_REDIRECT_URI=http://localhost:3001/api/unsolicited/callback
# UNSOLICITED_SCOPE=openid

# Override the token endpoint if it's not derivable from ACS host + resume path.
# UNSOLICITED_TOKEN_URL=https://localhost:8443/dev/oauth/token

# Signing key + cert used to sign the unsolicited Response. Auto-generated on
# first boot to server/keys/idp-signing.{key,crt}.pem if absent.
# UNSOLICITED_KEY_PATH=./server/keys/idp-signing.key.pem
# UNSOLICITED_CERT_PATH=./server/keys/idp-signing.crt.pem